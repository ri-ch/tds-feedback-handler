# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:port/dbname?sslmode=require
TDS_FB_CONNECTION_STRING=postgresql://user:password@localhost:5432/feedback?sslmode=require

# HTTP port to listen on (optional, defaults to 8080)
PORT=8080

# Database connection pool size (optional, defaults to 16)
DB_POOL_SIZE=16
